# .env.example — copy to .env and adjust. The backend (src/) reads these.

# --- datastores (match docker-compose.yml; host connects via published ports) ---
DATABASE_URL="postgresql://postgres:dev@localhost:5432/postgres?schema=public"
REDIS_URL="redis://localhost:6379"

# --- LiveKit ---
# Browser + token use the ws URL. Server-side EgressClient/RoomServiceClient need the
# HTTP URL; it's derived from LIVEKIT_URL automatically (ws->http) unless you set it.
LIVEKIT_URL="ws://localhost:7880"
# LIVEKIT_HTTP_URL="http://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret_change_me"

# --- recording paths ---
# REC_DIR is the HOST folder the stitch worker reads (bind-mounted to the egress
# container). EGRESS_OUTPUT_DIR is the matching path INSIDE that container
# (= egress.yaml local_output_directory). OUT_DIR is where stitched MP4s are written
# (host only). Defaults are relative to the repo, which is fine for local dev.
REC_DIR="./recordings"
EGRESS_OUTPUT_DIR="/out"
OUT_DIR="./stitched"

# --- app ---
PORT="3000"
# Origin of the Vite dev server, used for /api CORS.
WEB_ORIGIN="http://localhost:5173"

# Recording-consent notice version. Bump when you change the wording in src/lib.ts
# so older acceptances stop counting.
NOTICE_VERSION="v1"

# --- admin dashboard (HTTP Basic auth at /admin/*) ---
ADMIN_USER="admin"
ADMIN_PASSWORD="changeme"
